# Copy to supabase/.env.local for `supabase functions serve` during E2E.
# AI keys are optional — lookup falls back to Open Food Facts + keywords without them.

AI_VERDICT_ENABLED=false
CLAUDE_ENABLED=false
CLAUDE_API_KEY=
GEMINI_API_KEY=
GEMINI_ENABLED=false
# Dev override (production: superadmin Admin → Settings, app_config.gemini_lookup_empty_off).
GEMINI_LOOKUP_EMPTY_OFF=false
